# ---- CPA connection --------------------------------------------------------
# CPA management API base URL + management key (same as CPACodexKeeper).
CPA_ENDPOINT=http://127.0.0.1:8317
CPA_TOKEN=replace-with-your-management-key

# A downstream client api-key listed under `api-keys:` in config.yaml.
# ONLY needed if you turn on probing (CPA_ENABLE_LIVE_PROBE=true). Passive mode
# (the default) never sends requests, so you can leave this empty.
CPA_CLIENT_API_KEY=

# Optional outbound proxy for management/probe calls. Leave empty for localhost.
CPA_PROXY=

# Path to the CPA Usage Keeper SQLite DB. Empty = auto-detect the sibling
# cpa-usage-keeper_*/data/app.db.
CPA_USAGE_DB=

# ---- Scheduling ------------------------------------------------------------
# Daemon re-score interval (seconds). Default 3600 (hourly).
CPA_INTERVAL=3600

# ---- Probe / DB behavior ---------------------------------------------------
# Passive mode (default): score purely from the usage-keeper DB history -- zero
# extra quota. Set true to ALSO send a real chat request to each prefix-routable
# provider each round (costs quota; requires CPA_CLIENT_API_KEY above).
CPA_ENABLE_LIVE_PROBE=false
# The probe prompt — a real, small task (only used when probing is on).
CPA_PROBE_PROMPT=写一个解压zip文件的python脚本，只要核心代码
CPA_PROBE_MAX_TOKENS=64
CPA_PROBE_TIMEOUT=60
CPA_WORKER_THREADS=6

# Recent-window (days) used to read per-credential health from the usage DB.
CPA_RECENT_WINDOW_DAYS=7
# Minimum recent requests before DB fail% is trusted on its own.
CPA_MIN_SAMPLE=8

# Also flip the openai-compatibility `disabled` flag for dead providers.
# Default false: in passive mode a disabled provider gets no traffic, so the DB
# can never see it recover (one-way trap). Leaving it at priority 1 keeps it
# eligible for fallback so recovery is observed and it climbs back automatically.
CPA_DISABLE_DEAD=false

# ---- Which credential types to manage --------------------------------------
CPA_MANAGE_CODEX_KEY=true
CPA_MANAGE_OPENAI_COMPAT=true
CPA_MANAGE_GEMINI_KEY=true
CPA_MANAGE_CLAUDE_KEY=true

# ---- Priority ladder (HIGHER = served first under fill-first) --------------
# Entries at or above the pin floor are NEVER rewritten (premium OAuth /
# manual overrides). Keep this above the highest tier below.
CPA_PIN_FLOOR=5000

CPA_PRIO_HEALTHY=600
CPA_PRIO_GOOD=500
CPA_PRIO_USABLE=400
CPA_PRIO_FLAKY=300
CPA_PRIO_POOR=200
CPA_PRIO_DEAD=1

# ---- Fail% thresholds (percent) --------------------------------------------
CPA_HEALTHY_THRESHOLD=15
CPA_GOOD_THRESHOLD=30
CPA_USABLE_THRESHOLD=50
CPA_FLAKY_THRESHOLD=75
CPA_DEAD_THRESHOLD=95
